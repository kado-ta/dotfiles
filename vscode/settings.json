{
    "workbench.colorTheme": "One Dark Pro Darker",
    "workbench.colorCustomizations": {
        "editor.selectionBackground": "#5e8881", // 選択中テキスト
        "editor.selectionHighlightBackground": "#3d4242d0", // 選択中テキストと同じテキストのハイライト
        "editor.findMatchBackground": "#5691b3", // 検索ヒットの内、現在、フォーカスしているもの
        "editor.findMatchHighlightBackground": "#3b5768d0" // 検索にヒットしたテキストと同じテキスト
    },
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "workbench.iconTheme": "material-icon-theme",
    "editor.rulers": [
        110
    ],
    "editor.fontFamily": "HackGen35Nerd, Menlo, Monaco, 'Courier New', monospace",
    "editor.fontSize": 13,
    "editor.renderWhitespace": "all",
    "editor.tabSize": 2,
    "editor.formatOnType": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.renderControlCharacters": true,
    "editor.renderLineHighlight": "all",
    "editor.largeFileOptimizations": false,
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.formatOnPaste": true,
    "editor.suggest.filterGraceful": false,
    "diffEditor.renderSideBySide": false,
    "diffEditor.codeLens": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "explorer.autoReveal": false,
    "explorer.confirmDragAndDrop": false,
    "extensions.ignoreRecommendations": true,
    "files.autoSave": "afterDelay",
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "files.associations": {
        "*.painless": "groovy",
        "*.schema": "ruby",
        "*.html.erb": "erb"
    },
    "files.watcherExclude": {
        "/vendor/bundle/**": true,
        "/node_modules/**": true,
        "**/.git/**": true,
        "**/node_modules/**": true,
        "**/Applications/**": true,
        "**/Creative Cloud Files/**": true,
        "**/Library/**": true,
        "**/Dropbox/**": true,
        "**/Desktop/**": true,
        "**/Downloads/**": true,
        "**/Documents/**": true,
        "**/Music/**": true,
        "**/Pictures/**": true,
        "**/Public/**": true
    },
    "files.exclude": {
        "**/.hg": false,
        "/.DS_Store": true,
        "/.git": true,
        "/node_modules": true
    },
    "git.openRepositoryInParentFolders": "always",
    "search.exclude": {
        "/node_modules": true,
        "/vendor": true
    },
    "task.slowProviderWarning": true,
    "terminal.integrated.copyOnSelection": true,
    "terminal.external.osxExec": "iTerm.app",
    "window.commandCenter": true,
    "better-comments.tags": [
        {
            "tag": "TODO:",
            "color": "#000",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "#FFAB00",
            "bold": true,
            "italic": false
        },
        {
            "tag": "FIXME:",
            "color": "#fff",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "#FF4180",
            "bold": true,
            "italic": false
        },
        {
            "tag": "NOTE:",
            "color": "#000",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "#97DFFC",
            "bold": true,
            "italic": false
        }
    ],
    //
    // --------------------------------------------------------------------
    // Ruby
    // --------------------------------------------------------------------
    "[ruby]": {
        "editor.defaultFormatter": "Shopify.ruby-lsp",
        "editor.insertSpaces": true,
        "editor.semanticHighlighting.enabled": true
    },
    "rubyLsp.rubyVersionManager": {
        "identifier": "mise"
    },
    "rubyLsp.formatter": "rubocop",
    "rubyLsp.linters": [
        "rubocop",
    ],
    "[erb]": {
        "editor.defaultFormatter": "aliariff.vscode-erb-beautify",
        "editor.formatOnSave": false
    },
    // VSCode ERB Formatter/Beautify 拡張で使用する HTML フォーマッター: htmlbeautifier gem は、
    // ローカル環境へインストールして使用する。 gem install htmlbeautifier -N
    "vscode-erb-beautify.useBundler": false,
    //
    // --------------------------------------------------------------------
    // Terraform
    // --------------------------------------------------------------------
    "terraform.languageServer.enable": true,
    // ここは、絶対パスで設定する必要がある。
    "terraform.languageServer.terraform.path": "/Users/kado/.local/share/mise/shims/terraform",
    "terraform.languageServer.args": [
        "serve"
    ],
    "terraform.experimentalFeatures.validateOnSave": false,
    "[terraform]": {
        "editor.defaultFormatter": "hashicorp.terraform",
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "file"
    },
    "tfsec.binaryPath": "/Users/kado/.local/share/mise/shims/tfsec",
    //
    // --------------------------------------------------------------------
    // Python
    // --------------------------------------------------------------------
    "python.defaultInterpreterPath": "/Users/kado/.local/share/mise/installs/python/latest",
    "python.analysis.extraPaths": [
        // NOTE: Python のバージョンを変更した場合は、併せて下記パス内 "python3.11" も変更する必要あり。
        ".venv/lib/python3.11/site-packages"
    ],
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        // VSCode に black のエラーが表示される場合の対処方法。
        // https://code.visualstudio.com/docs/python/editing#_troubleshooting-formatting
        "editor.formatOnPaste": false,
        "editor.formatOnSaveMode": "file",
        // 保存時に isort を実行する。
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "isort.args": [
        "--profile black" // isort の black 互換設定
    ],
    // autoDocstring のスタイルを Google スタイルに設定する。
    "autoDocstring.docstringFormat": "google",
    "flake8.path": [
        "./.venv/bin/flake8"
    ],
    "flake8.args": [
        // flake8 の設定は、プロジェクト直下の .flake8 ファイルに記載する。
        "--config=${workspaceFolder}/.flake8"
    ],
    "mypy-type-checker.args": [
        "--follow-imports=skip", // インポートしたモジュールの型ヒントチェックを行わない。
        "--ignore-missing-imports", // 解決できないモジュールのインポートを無視する。
        "--show-column-numbers", // エラーメッセージにカラム・オフセットも表示するようにする。
        "--warn-return-any", // 返り値が正確に明示されていないことを警告する。
        "--disallow-untyped-defs", // 返り値が明示されていない関数をエラーとして扱う。
        "--disallow-untyped-calls" // 返り値の型をが明示されていない関数をエラーとして扱う。
    ],
    "mypy-type-checker.path": [
        ".venv/bin/mypy"
    ],
    "mypy-type-checker.severity": {
        "error": "Warning"
    },
    "html.format.wrapLineLength": 0,
    "[html]": {
        "editor.defaultFormatter": null
    },
    "[markdown]": {
        "files.trimTrailingWhitespace": false,
        "editor.wordWrap": "off"
    },
    "[json]": {
        "editor.defaultFormatter": null
    },
    "spectral.validateLanguages": [
        "yaml",
        "json"
    ],
    "spectral.validateFiles": [
        "**/openapi.yaml",
        "**/openapi.yml"
    ],
    "hediet.vscode-drawio.resizeImages": null,
    "vscode-erb-beautify.keepBlankLines": 1,
    "circleci.hostUrl": "",
    "projectManager.tags": [
        "Personal",
        "HomeLoan",
        "HomeLoan/Infra",
        "NUMM"
    ],
    // Claude Code
    "claudeCode.preferredLocation": "panel",
    // --------------------------------------------------------------------
    "markdown-pdf.mermaidServer": "https://unpkg.com/mermaid@10.4.0/dist/mermaid.js",
    // ローカルファイルプロトコルの扱いに対する確認ダイアログを表示しない。
    "security.promptForLocalFileProtocolHandling": false
}
